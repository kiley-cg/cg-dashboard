# ---- Auth.js ----
AUTH_SECRET=                 # openssl rand -hex 32
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Only sign-ins with this email domain are allowed.
ALLOWED_EMAIL_DOMAIN=colorgraphicswa.com

# ---- Database (Neon Postgres) ----
DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# ---- Syncore (Facilisgroup) ----
SYNCORE_BASE_URL=https://api.syncore.app/v2
SYNCORE_API_KEY=

# Job Follow-Ups is not in the v2 REST API — it's only available via the
# authenticated web UI at ateasesystems.net. The CSR dashboard scrapes that
# UI using a cached cookie session (see src/lib/syncore/webui.ts). Use the
# same credentials a CSR/manager would use to sign in to ateasesystems.net.
SYNCORE_USERNAME=
SYNCORE_PASSWORD=

# Numeric customerServiceRepId values from Syncore's Follow-Ups filter
# dropdown. Find by filtering the page to one CSR and copying the URL.
CSR_VALERIE_ID=13379
CSR_JEREMIAH_ID=13470

# ---- CSR Dashboard ----
# Comma-separated list of emails that may access /dashboard. Anyone signed
# in with a different (but allowed-domain) email is silently denied.
MANAGER_EMAILS=kiley@colorgraphicswa.com,voshte@colorgraphicswa.com
# Shared secret required by the snapshot + digest cron routes. Generate with
# `openssl rand -hex 32` and set the same value on Vercel.
CRON_SECRET=
# Comma-separated recipients for the daily morning digest email.
DIGEST_RECIPIENTS=kiley@colorgraphicswa.com,voshte@colorgraphicswa.com
# Resend API key (https://resend.com). The "from" address must be on a
# domain you've verified inside Resend.
RESEND_API_KEY=
DIGEST_FROM_EMAIL=alerts@updates.colorgraphicswa.com
# Optional. If From: lives on a sending-only subdomain (e.g. updates.…)
# replies will bounce — set a Reply-To pointing at a real mailbox/group.
DIGEST_REPLY_TO=alerts@colorgraphicswa.com

# ---- SanMar PromoStandards Inventory 2.0.0 + Standard Pricing ----
SANMAR_WSDL_URL=https://ws.sanmar.com:8080/promostandards/InventoryServiceBindingV2final?WSDL
SANMAR_PRICING_WSDL_URL=https://ws.sanmar.com:8080/SanMarWebService/SanMarPricingServicePort?wsdl
SANMAR_WS_ID=             # SanMar.com username
SANMAR_WS_PASSWORD=       # SanMar.com password
SANMAR_CUSTOMER_NUMBER=   # required for the pricing call (mySpecialPrice etc.)

# ---- S&S Activewear REST API (api.ssactivewear.com) ----
# We use S&S's REST API rather than their PromoStandards SOAP because the
# REST endpoints are better documented and avoid node-soap WSDL parsing
# bugs. Auth is HTTP Basic with the account number as the username and
# the API key as the password.
SS_API_BASE_URL=https://api.ssactivewear.com/v2

# ---- UPS Rating + Time-In-Transit ----
# Used for per-Sales-Order freight estimates and real transit-day quotes.
# Create an app at https://developer.ups.com → My Apps → Rating product.
# UPS_ACCOUNT_NUMBER is optional; without it we get list rates instead of
# your contracted negotiated rate.
UPS_CLIENT_ID=
UPS_CLIENT_SECRET=
UPS_ACCOUNT_NUMBER=
UPS_ENV=production         # production | test (CIE sandbox)
# CG's pickup-of-record on the UPS account. UPS only releases negotiated
# rates when the Shipper block carries the full street address that
# matches the account on file — a ZIP-only Shipper falls back to list
# rates. ShipFrom remains the vendor warehouse ZIP (UPS supports the
# split, so packages physically originate at the vendor while the bill-to
# and tariff come from CG's account).
UPS_SHIPPER_NAME=Color Graphics
UPS_SHIPPER_STREET=
UPS_SHIPPER_CITY=
UPS_SHIPPER_STATE=         # two-letter, e.g. WA
UPS_SHIPPER_ZIP=
SS_WS_ID=          # your S&S account / customer number
SS_WS_PASSWORD=    # the API key emailed by api@ssactivewear.com

# ---- Cutter & Buck PromoStandards Inventory 2.0.0 ----
# Credentials issued by CBEDI@cutterbuck.com. Pricing requires the separate
# /ProductConfigPricing.asmx endpoint (not yet wired) — rows render with
# cost = "—" for C&B until that's added.
CB_WSDL_URL=https://api.cbcorporate.com/promostandards/InventoryService121.asmx?wsdl
CB_WS_ID=
CB_WS_PASSWORD=

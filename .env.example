# ---- Auth.js ----
AUTH_SECRET=                 # openssl rand -hex 32
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Only sign-ins with this email domain are allowed.
ALLOWED_EMAIL_DOMAIN=colorgraphicswa.com

# ---- Database (Neon Postgres) ----
DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# ---- Syncore (Facilisgroup) ----
SYNCORE_BASE_URL=https://api.syncore.app/v2
SYNCORE_API_KEY=

# ---- SanMar PromoStandards Inventory 2.0.0 + Standard Pricing ----
SANMAR_WSDL_URL=https://ws.sanmar.com:8080/promostandards/InventoryServiceBindingV2final?WSDL
SANMAR_PRICING_WSDL_URL=https://ws.sanmar.com:8080/SanMarWebService/SanMarPricingServicePort?wsdl
SANMAR_WS_ID=             # SanMar.com username
SANMAR_WS_PASSWORD=       # SanMar.com password
SANMAR_CUSTOMER_NUMBER=   # required for the pricing call (mySpecialPrice etc.)

# ---- S&S Activewear REST API (api.ssactivewear.com) ----
# We use S&S's REST API rather than their PromoStandards SOAP because the
# REST endpoints are better documented and avoid node-soap WSDL parsing
# bugs. Auth is HTTP Basic with the account number as the username and
# the API key as the password.
SS_API_BASE_URL=https://api.ssactivewear.com/v2

# ---- UPS Rating + Time-In-Transit ----
# Used for per-Sales-Order freight estimates and real transit-day quotes.
# Create an app at https://developer.ups.com → My Apps → Rating product.
# UPS_ACCOUNT_NUMBER is optional; without it we get list rates instead of
# your contracted negotiated rate.
UPS_CLIENT_ID=
UPS_CLIENT_SECRET=
UPS_ACCOUNT_NUMBER=
UPS_ENV=production         # production | test (CIE sandbox)
# Multiplier applied to the raw UPS list rate before display, only when
# UPS does NOT return negotiated rates. Job 32268 actual hit at exactly
# 0.66 (actual $167.58 vs raw quote $253.35), but the default is biased
# high (0.75) to err on the side of overestimating — underquoting
# freight to a customer is worse than overquoting. Reset to "1" once
# UPS starts returning negotiated rates, otherwise the factor would
# double-count.
UPS_RATE_CALIBRATION=0.75
SS_WS_ID=          # your S&S account / customer number
SS_WS_PASSWORD=    # the API key emailed by api@ssactivewear.com

# ---- Cutter & Buck PromoStandards Inventory 2.0.0 ----
# Credentials issued by CBEDI@cutterbuck.com. Pricing requires the separate
# /ProductConfigPricing.asmx endpoint (not yet wired) — rows render with
# cost = "—" for C&B until that's added.
CB_WSDL_URL=https://api.cbcorporate.com/promostandards/InventoryService121.asmx?wsdl
CB_WS_ID=
CB_WS_PASSWORD=
